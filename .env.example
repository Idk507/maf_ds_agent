# =====================================================================
# DS Agent — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =====================================================================

# ── Azure AI Foundry / Azure OpenAI ──────────────────────────────────
AI_FOUNDRY_PROJECT_ENDPOINT=https://your-resource.openai.azure.com
AI_FOUNDRY_API_VERSION=2024-12-01-preview
AI_FOUNDRY_API_KEY=your-api-key-here

# Deployment names (match what you set in Azure Portal)
AZURE_OPENAI_PRIMARY_DEPLOYMENT=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── MCP Server Ports ─────────────────────────────────────────────────
TRACKING_MCP_PORT=8100
DS_TOOLS_MCP_PORT=8101
BUG_LOG_MCP_PORT=8102

# Full MCP endpoint URLs
# FastAPI mounts at /mcp, FastMCP adds its own /mcp suffix → /mcp/mcp
TRACKING_MCP_URL=http://localhost:8100/mcp/mcp
DS_TOOLS_MCP_URL=http://localhost:8101/mcp/mcp
BUG_LOG_MCP_URL=http://localhost:8102/mcp/mcp

# ── Pipeline Limits ───────────────────────────────────────────────────
PIPELINE_TOKEN_BUDGET=500000
PIPELINE_MAX_RALPH_ITERATIONS=8
# Set to false to auto-approve all human gates (dev/test mode)
PIPELINE_HUMAN_IN_THE_LOOP=true

# ── Memory / Data Paths ───────────────────────────────────────────────
MEMORY_DB_PATH=data/memory.db
SEMANTIC_MEMORY_PATH=data/semantic_memory.json
PROCEDURAL_MEMORY_PATH=data/procedural_memory.json
TRACKING_DB_PATH=data/tracking.db
BUGLOG_DB_PATH=data/buglog.db

# ── Output Directory ──────────────────────────────────────────────────
OUTPUT_BASE_DIR=outputs

# ── OpenTelemetry (optional — set to enable tracing export) ──────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=ds-agent
