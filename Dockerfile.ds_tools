# Dockerfile.ds_tools — DS Tools MCP Server (port 8101)
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# DS Tools needs heavier ML deps
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        mcp==1.26.0 \
        starlette \
        "uvicorn[standard]" \
        python-dotenv \
        pydantic-settings \
        duckduckgo-search \
        pandas \
        numpy \
        scikit-learn \
        matplotlib \
        seaborn \
        aiofiles \
        httpx \
        rich

COPY mcp_servers/ds_tools/ mcp_servers/ds_tools/
COPY mcp_servers/__init__.py mcp_servers/
COPY config/ config/

RUN mkdir -p data/artefacts logs

ENV DS_TOOLS_MCP_PORT=8101

EXPOSE 8101

HEALTHCHECK --interval=10s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8101/health || exit 1

CMD ["uvicorn", "mcp_servers.ds_tools.server:app", \
     "--host", "0.0.0.0", "--port", "8101", \
     "--log-level", "info", "--no-access-log"]
